<!DOCTYPE html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Travel Advisor</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

    <link rel="stylesheet" href="styles.css">
</head>

<body>
    <!-- Full-screen map -->
    <div id="map"></div>

    <!-- Floating search card (top-center, doesn't cover map content much) -->
    <div id="search-card" class="card shadow-sm">
        <div class="card-body p-2">
            <form id="recommend-form" class="d-flex gap-2 align-items-center">
                <i class="bi bi-geo-alt-fill text-primary fs-5 ms-1 d-none d-sm-inline"></i>
                <input type="text" id="recommend-terms" class="form-control form-control-sm"
                    placeholder="Find places near the map center..." autocomplete="off" />
                <button id="recommend-btn" type="submit" class="btn btn-primary btn-sm text-nowrap">
                    <span id="recommend-btn-label">
                        <i class="bi bi-search"></i>
                        <span class="d-none d-sm-inline">Search</span>
                    </span>
                    <span id="recommend-btn-spinner" class="d-none">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    </span>
                </button>
                <button id="results-toggle-btn" type="button"
                    class="btn btn-outline-secondary btn-sm position-relative d-none"
                    data-bs-toggle="offcanvas" data-bs-target="#results-offcanvas"
                    aria-controls="results-offcanvas" title="Show results">
                    <i class="bi bi-list-ul"></i>
                    <span id="results-count-badge"
                        class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary">
                        0
                    </span>
                </button>
            </form>
            <div id="recommend-error" class="alert alert-danger alert-sm py-1 px-2 mb-0 mt-2 d-none small"></div>
        </div>
    </div>

    <!-- Off-canvas results panel: doesn't block the map (no backdrop, scrollable) -->
    <div class="offcanvas offcanvas-end" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1"
        id="results-offcanvas" aria-labelledby="results-offcanvas-label">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="results-offcanvas-label">
                <i class="bi bi-pin-map-fill text-primary"></i>
                Recommendations
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div id="recommend-results" class="list-group list-group-flush"></div>
            <div id="recommend-empty" class="text-center text-muted py-5 px-3 d-none">
                <i class="bi bi-compass display-4 d-block mb-2"></i>
                <p class="mb-0">Search for places to see recommendations here.</p>
            </div>
        </div>
    </div>

    <!-- Google Maps API (must load before GoogleMutant) -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=AQ.Ab8RN6Ju4MkVN482yd6mIJ31CKO9nU3ugLSnjkM4AAW13A6Z7w"></script>
    <script src="https://unpkg.com/leaflet.gridlayer.googlemutant@latest/dist/Leaflet.GoogleMutant.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Axios -->
    <script src="https://cdn.jsdelivr.net/npm/axios@1.12.2/dist/axios.min.js"></script>

    <!-- Our scripts -->
    <script src="data.js"></script>
    <script src="map.js"></script>
    <script src="script.js"></script>
</body>

</html>